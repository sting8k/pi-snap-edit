{
  "name": "pi-quickedit",
  "version": "0.1.0",
  "description": "Hash-anchored read and quick_edit tools for Pi",
  "keywords": [
    "pi-package",
    "pi-extension",
    "quick-edit",
    "hash-anchored-edit",
    "coding-agent"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.41"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.73.0",
    "@mariozechner/pi-tui": "^0.73.0",
    "@types/node": "^24.3.0",
    "typescript": "^5.9.3"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.6.0"
  }
}
