{
  "name": "pi-snap-edit",
  "version": "4.0.0",
  "description": "Fast, precise, script-free edits for Pi agents",
  "keywords": [
    "pi-package",
    "pi-extension",
    "snap-edit",
    "fast-edit",
    "anchored-edit",
    "atomic-edit",
    "coding-agent"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "rm -rf tmp/test-dist && tsc -p tsconfig.test.json && node --test tmp/test-dist/test/*.test.js"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.41"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "@earendil-works/pi-tui": "^0.78.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "@earendil-works/pi-tui": "^0.78.0",
    "@types/node": "^24.3.0",
    "typescript": "^5.9.3"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.6.0"
  }
}
